# ──────────────────────────────────────────
# AI Supplier Risk Copilot — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────

# App
APP_NAME=AI Supplier Risk Copilot
APP_ENV=development
APP_VERSION=0.1.0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=supplier_risk_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
DATABASE_URL=postgresql://admin:admin123@db:5432/supplier_risk_db

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Supplier Risk Copilot

# AI Module
MODEL_PATH=ai/models/risk_model.pkl
RISK_THRESHOLD_HIGH=0.7
RISK_THRESHOLD_MEDIUM=0.4
